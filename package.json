{
  "name": "shadowclaw",
  "version": "1.7.1",
  "type": "module",
  "license": "AGPL-3.0",
  "description": "Browser-native personal AI assistant.",
  "author": "Karl Herrick <me@karlherrick.com>",
  "main": "dist/electron/main.cjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:clean": "node bin/rimraf.mjs dist && node bin/rimraf.mjs dist-electron",
    "build:copy:all:assets": "cross-env COPY_ALL_ASSETS=true npm run build",
    "build:pkg:get:meta": "git rev-parse HEAD",
    "build:pkg:meta": "node -e \"import fs from 'node:fs/promises';const m=process.argv[1],f='dist/public/index.html',s=await fs.readFile(f,'utf8');await fs.writeFile(f,s.replace(/<meta\\s+name=\\\"revision\\\"\\s+content=\\\"[^\\\"]*\\\"\\s*\\/>/,'<meta name=\\\"revision\\\" content=\\\"'+m+'\\\" />'));\"",
    "build:prod": "cross-env NODE_ENV=production npm run build",
    "build:service-worker": "npm run -s clean:service-worker && workbox generateSW src/service-worker/workbox-config.cjs",
    "build": "node bin/build.mjs",
    "clean:service-worker": "node bin/rimraf.mjs dist/public/workbox-*.js && node bin/rimraf.mjs dist/public/service-worker.js",
    "deploy:gh-pages": "npm run -s build:prod && gh-pages -f -m \"npm run deploy:gh-pages\" -d dist/public -r git@github.com:xt-ml/shadow-claw.git",
    "e2e:install": "npx playwright install",
    "e2e": "node bin/rimraf.mjs .cache/e2e-database && npx playwright test",
    "electron:build:mac": "npm run build && npm run build:service-worker && electron-builder --mac",
    "electron:build:server:mac": "npm run build && electron-builder --mac -c.main=dist/server.js",
    "electron:build:server:win": "npm run build && electron-builder --win -c.main=dist/server.js",
    "electron:build:server": "npm run build && electron-builder -c.main=dist/server.js",
    "electron:build:win": "npm run build && npm run build:service-worker && electron-builder --win",
    "electron:build": "npm run build && npm run build:service-worker && electron-builder",
    "electron": "npm run build && electron dist/electron/main.cjs",
    "format": "npx prettier **/*.{html,css,ts,js,mjs} --write",
    "rollup": "rollup -c",
    "start": "npm run -s build && node dist/server.js",
    "test": "npm run -s tsc && cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "tsc:agent:worker": "tsc --noEmit -p tsconfig.agent.worker.json",
    "tsc:app": "tsc --noEmit -p tsconfig.json",
    "tsc:server": "tsc --noEmit -p tsconfig.server.json",
    "tsc:service:worker": "tsc --noEmit -p tsconfig.service.worker.json",
    "tsc:test": "tsc --noEmit -p tsconfig.test.json",
    "tsc:transformers:js:worker": "tsc --noEmit -p tsconfig.transformers-js.worker.json",
    "tsc": "npm -s run tsc:app && npm -s run tsc:agent:worker && npm -s run tsc:transformers:js:worker && npm -s run tsc:service:worker && npm -s run tsc:server && npm -s run tsc:test"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1041.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1041.0",
    "@aws-sdk/credential-providers": "^3.1041.0",
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-auth": "^1.10.1",
    "@google/genai": "^2.0.1",
    "@huggingface/transformers": "^4.2.0",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-urlrewrite": "^2.0.3",
    "imapflow": "^1.3.3",
    "isomorphic-git": "^1.37.6",
    "nodemailer": "^8.0.7",
    "smart-buffer": "^4.2.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@mcp-b/webmcp-polyfill": "^2.2.0",
    "@mcp-b/webmcp-types": "^2.2.0",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/dom-chromium-ai": "^0.0.16",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/serviceworker": "^0.0.196",
    "@types/tcp-port-used": "^1.0.4",
    "@zip.js/zip.js": "^2.8.26",
    "assert": "^2.1.0",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "cross-env": "^10.1.0",
    "cssnano": "^7.1.7",
    "dompurify": "^3.4.2",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "gh-pages": "^6.3.0",
    "highlight.js": "^11.11.1",
    "highlighted-code": "^0.3.7",
    "htmlnano": "^3.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jszip": "^3.10.1",
    "just-bash": "^2.14.2",
    "marked": "^18.0.3",
    "path-browserify": "^1.0.1",
    "pdfjs-dist": "^5.7.284",
    "postcss": "^8.5.13",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "rollup": "^4.60.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "signal-polyfill": "^0.2.2",
    "stream-browserify": "^3.0.0",
    "tcp-port-used": "^1.0.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "util": "^0.12.5",
    "v86": "^0.5.355",
    "workbox-cli": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "build": {
    "appId": "io.github.xt-ml.shadowclaw",
    "productName": "ShadowClaw",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/electron/main.cjs",
      "dist/**",
      "assets/**",
      "node_modules/**",
      "!node_modules/**/test/**",
      "!node_modules/**/*.test.*",
      "!node_modules/**/*.spec.*",
      "!**/*.test.ts",
      "!**/test/**",
      "!e2e/**"
    ],
    "win": {
      "target": [
        "nsis",
        "msi",
        "zip"
      ],
      "icon": "assets/icons/512.png"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "assets/icons/512.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "snap"
      ],
      "icon": "assets/icons/512.png",
      "asarUnpack": [
        "**/*.node",
        "**/libffmpeg.so*"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
