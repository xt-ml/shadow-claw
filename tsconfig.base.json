{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": false,
    "types": [
      "jest",
      "dom-chromium-ai"
    ],
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}