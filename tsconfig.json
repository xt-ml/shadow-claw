{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out",
    "rootDir": "src",
    "lib": [
      "ESNext",
      "DOM"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/service-worker/init.ts",
    "src/index.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "coverage",
    "dist",
    "e2e",
    "node_modules",
    "src/server",
    "src/service-worker",
    "src/worker"
  ]
}