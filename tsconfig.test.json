{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
      "jest"
    ]
  },
  "include": [
    "src/**/*.css",
    "src/**/*.html",
    "src/**/*.ts",
  ],
  "exclude": [
